# Telegram alert credentials
# 1. Open Telegram, search for @BotFather, send /newbot
# 2. Copy the token it gives you
# 3. Start a chat with your bot, send any message
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Copy your chat_id from the response
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Twelve Data — hourly forex price data for backtesting
# Get a free key at https://twelvedata.com/apikey (no credit card, instant)
TWELVEDATA_API_KEY=your_twelvedata_key_here

# OANDA — alternative intraday price provider (blocked in some networks)
OANDA_API_KEY=your_oanda_token_here
OANDA_USE_LIVE=0
